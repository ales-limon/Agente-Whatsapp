# API de Anthropic (Claude). Sacala de https://console.anthropic.com (empieza con sk-ant-)
ANTHROPIC_API_KEY=

# Modelo de Claude. Haiku es rapido y barato; ideal para responder chats.
CLAUDE_MODELO=claude-haiku-4-5-20251001
# Modelo para negocios A DOMICILIO (flujo de registro/identificacion mas exigente).
# Sonnet obedece mejor y llama las herramientas de forma confiable. Ajusta el ID al
# que soporte tu cuenta si hace falta.
CLAUDE_MODELO_DOMICILIO=claude-sonnet-5

# Credenciales de Twilio. En https://console.twilio.com (Account Info).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Validar la firma de Twilio. 1 = si (recomendado). 0 = solo para la primera prueba local.
VALIDAR_FIRMA_TWILIO=1

# Content SID de las plantillas aprobadas de WhatsApp (Content Template Builder).
# Permiten enviar avisos aunque el destinatario no haya escrito en las ultimas 24h.
# Si se dejan vacias, el sistema cae a mensaje libre (solo entrega dentro de la ventana de 24h).
# El orden de las variables {{1}},{{2}}... lo arma src/notificaciones.php; no cambiar el cuerpo aprobado.
TWILIO_PLANTILLA_CITA=HXb0c1f8deff43a6a9773dadbfeec2cc9b
TWILIO_PLANTILLA_REAGENDADA=HX532d87ae8c61955c43f3365a452acd19
TWILIO_PLANTILLA_CANCELADA=HX694604da601878d429c9e3d890455640
TWILIO_PLANTILLA_RECORDATORIO=HXa7a13cca0ea1339d3d3b4bff4fb90369
# Aviso al dueño cuando un desconocido pide atencion/visita (escalar_a_humano).
# Variables: {{1}} negocio, {{2}} numero del cliente, {{3}} motivo. Aprobar en Meta y pegar el SID.
TWILIO_PLANTILLA_ESCALACION=

# URL publica exacta del webhook (la que registras en Twilio). Necesaria para validar la firma.
# Ej: https://abc123.ngrok-free.app/webhook.php
WEBHOOK_URL=

# Entorno: 'local' muestra errores; cualquier otro valor los oculta (produccion).
APP_ENV=local

# Zona horaria del negocio (para que "hoy" y las fechas relativas salgan bien)
ZONA_HORARIA=America/Mexico_City

# Correo (recuperacion de contraseña). En produccion conectar un SMTP real.
CORREO_FROM=no-reply@tudominio.com
# URL base para los enlaces de los correos (si se deja vacio se infiere del request)
APP_URL=

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agente_whatsapp
DB_USER=root
DB_PASS=
