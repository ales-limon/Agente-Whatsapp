# API de Anthropic (Claude). Sacala de https://console.anthropic.com (empieza con sk-ant-)
ANTHROPIC_API_KEY=

# Modelo de Claude. Haiku es rapido y barato; ideal para responder chats.
CLAUDE_MODELO=claude-haiku-4-5-20251001

# Credenciales de Twilio. En https://console.twilio.com (Account Info).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Validar la firma de Twilio. 1 = si (recomendado). 0 = solo para la primera prueba local.
VALIDAR_FIRMA_TWILIO=1

# URL publica exacta del webhook (la que registras en Twilio). Necesaria para validar la firma.
# Ej: https://abc123.ngrok-free.app/webhook.php
WEBHOOK_URL=

# Entorno: 'local' muestra errores; cualquier otro valor los oculta (produccion).
APP_ENV=local

# Zona horaria del negocio (para que "hoy" y las fechas relativas salgan bien)
ZONA_HORARIA=America/Mexico_City

# Correo (recuperacion de contraseña). En produccion conectar un SMTP real.
CORREO_FROM=no-reply@tudominio.com
# URL base para los enlaces de los correos (si se deja vacio se infiere del request)
APP_URL=

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agente_whatsapp
DB_USER=root
DB_PASS=
