# Bloquear el .env y archivos sensibles del acceso web
<FilesMatch "^\.env">
  Require all denied
</FilesMatch>
<FilesMatch "\.(log|md|sql|example)$">
  Require all denied
</FilesMatch>

# Scripts que solo deben correr por CLI / deploy, nunca desde el navegador
<FilesMatch "^(instalar|probar)\.php$">
  Require all denied
</FilesMatch>
